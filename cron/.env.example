# Vercel Cron — Weekly Digest
# Copy to .env for local testing with `vercel dev`

# Vercel auto-generates and injects CRON_SECRET in production.
# For local testing, set any string here.
CRON_SECRET=your-local-secret

# Resend — required for sends
RESEND_API_KEY=re_...
RESEND_AUDIENCE_ID=...
EMAIL_FROM=newsletter@paradoxofacceptance.xyz
EMAIL_REPLY_TO=nick@paradoxofacceptance.xyz

# Supabase — optional; skips community query + logging if absent
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Twitter / X auto-post — optional; skips tweet if absent
# OAuth 1.0a credentials for @quiet_drift
# Get from: https://developer.twitter.com (project app > Keys and Tokens)
TWITTER_API_KEY=your_consumer_key_here
TWITTER_API_SECRET=your_consumer_secret_here
TWITTER_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCESS_SECRET=your_access_token_secret_here
