# Vercel Cron — Weekly Digest
# Copy to .env for local testing with `vercel dev`

# Vercel auto-generates and injects CRON_SECRET in production.
# For local testing, set any string here.
CRON_SECRET=your-local-secret

# Resend — required for sends
RESEND_API_KEY=re_...
RESEND_AUDIENCE_ID=...
EMAIL_FROM=newsletter@paradoxofacceptance.xyz
EMAIL_REPLY_TO=nick@paradoxofacceptance.xyz

# Supabase — optional; skips community query + logging if absent
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
