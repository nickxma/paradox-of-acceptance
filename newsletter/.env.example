# Resend API credentials
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Resend Audience ID (created after you add your domain)
# Find in: Resend dashboard > Audiences
RESEND_AUDIENCE_ID=your_audience_id_here

# The from address (must use your verified domain)
EMAIL_FROM=newsletter@paradoxofacceptance.xyz

# Optional: reply-to address
EMAIL_REPLY_TO=nick@paradoxofacceptance.xyz

# Path to the audience CSV (relative or absolute)
AUDIENCE_CSV_PATH=../../../Obsidian/02_Objectives/02_Mindfulness/Audience/audience-list.csv

# ─── Send Pipeline (server.ts) ────────────────────────────────────────────────

# API key to authenticate POST /send requests (legacy endpoint)
# Generate with: openssl rand -hex 32
SEND_API_KEY=your_send_api_key_here

# Admin secret to authenticate POST /api/newsletter/send
# Generate with: openssl rand -hex 32
ADMIN_SECRET=your_admin_secret_here

# Email address to use in test mode sends (POST /api/newsletter/send with testMode: true)
TEST_EMAIL=nick@example.com

# Secret for signing unsubscribe tokens (HMAC-SHA256)
# Generate with: openssl rand -hex 32
UNSUBSCRIBE_SECRET=your_unsubscribe_secret_here

# Port for the newsletter send server (default: 3200)
PORT=3200

# IMPORTANT: Full-list sends are blocked until Nick explicitly approves.
# Set this to true ONLY after Nick has reviewed and approved the send.
# Default: false (blocked)
ALLOW_FULL_LIST_SEND=false

# ─── Resend Webhook ──────────────────────────────────────────────────────────
# Signing secret for validating incoming Resend webhook payloads (svix-signature header).
# Steps to register:
#   1. Deploy the newsletter server (POST /api/webhooks/resend is the endpoint).
#   2. Go to Resend dashboard → Webhooks → Add endpoint.
#   3. URL: https://<your-server>/api/webhooks/resend
#   4. Subscribe to: email.opened, email.clicked, email.bounced, email.complained, email.unsubscribed
#   5. Copy the signing secret (starts with whsec_) and paste it here.
# Get from: Resend dashboard > Webhooks > <endpoint> > Signing Secret
RESEND_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here

# ─── Send Log (Supabase) ──────────────────────────────────────────────────────
# Optional — if set, each broadcast is logged to the newsletter_sends table.
# Run newsletter_sends.sql in Supabase SQL Editor to create the table first.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── OpenAI (essay embeddings + related essays) ──────────────────────────────
# Optional — if set, essay embeddings are generated for semantic similarity search.
# Used by GET /api/essays/:slug/related. Falls back to tag-based similarity if unset.
# Run newsletter/essay-embeddings-schema.sql in Supabase SQL Editor first.
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_key_here

# ─── Convergence MVP proxy (admin overview page) ─────────────────────────────
# Base URL of the Convergence MVP deployment (no trailing slash)
CONVERGENCE_MVP_URL=https://convergence-mvp.vercel.app
# Admin wallet address for /api/admin/* endpoints on the MVP
CONVERGENCE_ADMIN_WALLET=0x0000000000000000000000000000000000000000
